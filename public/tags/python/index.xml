&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; &lt;span class="n"&gt;Py_TPFLAGS_LONG_SUBCLASS&lt;/span&gt; &lt;span class="o"&gt;|&lt;/span&gt;
